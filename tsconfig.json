{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],

        // Allow incremental migration: existing .js files are included but not
        // type-checked until explicitly opted in with @ts-check or renamed to .ts
        "allowJs": true,
        "checkJs": false,

        // Start permissive; tighten per-file as modules are migrated to TypeScript
        "strict": false,
        "noImplicitAny": false,

        "sourceMap": true,
        // Re-enable declaration emit in a later step once real TypeScript modules exist
        // "declaration": true,
        // "declarationDir": "dist/types",

        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,

        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "temp",
        // Vendored third-party libs — not migrated, excluded from compilation
        "src/lib",
        // Grunt build-tool scripts — not app source
        "src/smk-tags.js",
        "build"
    ]
}
