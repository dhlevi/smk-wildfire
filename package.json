{
  "version": "1.1.0",
  "name": "@qqnluaq/smk",
  "title": "Simple Map Kit",
  "description": "A simple way to add a map your application.",
  "author": "Ben Jubb <benjubb@gmail.com>",
  "license": "APSL-2.0",
  "homepage": "https://qqnluaq.github.io/smk/",
  "repository": "github:qqnluaq/smk",
  "main": "dist/smk.umd.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "concurrently --kill-others \"npm:build:watch\" \"npm:serve\"",
    "build": "vite build && vite build --config vite.config.standalone.js",
    "build:lite": "vite build",
    "build:standalone": "vite build --config vite.config.standalone.js",
    "build:watch": "vite build --watch",
    "release": "npm run build",
    "serve": "live-server . --open=debug --wait=100 --watch=dist/smk.umd.js,debug,test",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@turf/turf": "5.1.6",
    "@types/esri-leaflet": "3.0.4",
    "@types/jquery": "4.0.0",
    "@types/leaflet": "1.9.21",
    "@types/proj4": "2.5.6",
    "concurrently": "5.3.0",
    "esri-leaflet": "3.0.19",
    "esri-leaflet-vector": "4.3.1",
    "jsdom": "29.0.2",
    "leaflet": "1.7.1",
    "live-server": "1.2.2",
    "maplibre-gl": "5.24.0",
    "material-design-icons-iconfont": "6.7.0",
    "proj4": "2.4.4",
    "qunit": "2.25.0",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue": "^2.7.16"
  }
}
