{
  "version": "1.1.0",
  "name": "@qqnluaq/smk",
  "title": "Simple Map Kit",
  "description": "A simple way to add a map your application.",
  "author": "Ben Jubb <benjubb@gmail.com>",
  "license": "APSL-2.0",
  "homepage": "https://qqnluaq.github.io/smk/",
  "repository": "github:qqnluaq/smk",
  "main": "dist/smk.umd.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "concurrently --kill-others \"npm:build:watch\" \"npm:serve\"",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "release": "vite build",
    "serve": "live-server . --open=debug --wait=100 --watch=dist/smk.umd.js,debug,test",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "5.3.0",
    "jsdom": "29.0.2",
    "live-server": "1.2.2",
    "material-design-icons-iconfont": "6.7.0",
    "qunit": "2.25.0",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
